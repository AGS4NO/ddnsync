# Required: DNSimple account access token (NOT a user token).
# Create at https://dnsimple.com/user → Access tokens.
DNSIMPLE_TOKEN=

# Required: Basic auth credentials the router presents to ddnsync.
AUTH_USER=
AUTH_PASS=

# Optional: listen address (default :8245)
# LISTEN_ADDR=:8245

# Optional: API base. Point at the sandbox while testing.
# DNSIMPLE_API=https://api.sandbox.dnsimple.com

# Optional: TTL applied to newly created records (default 60s).
# Existing records keep their TTL on update.
# RECORD_TTL=60
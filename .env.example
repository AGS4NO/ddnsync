# Required: DNSimple account access token (NOT a user token).
# Create at https://dnsimple.com/user → Access tokens.
DNSIMPLE_TOKEN=

# ---- Server mode -----------------------------------------------------------
# Accepts noip / dyndns2 GET requests from a router or other client.
# Set LISTEN_ADDR=off to disable; AUTH_USER/AUTH_PASS are then optional.

# host:port to bind. "off" disables the HTTP server.
# LISTEN_ADDR=:8245

# Required if the server is enabled.
AUTH_USER=
AUTH_PASS=

# ---- Poll mode -------------------------------------------------------------
# ddnsync self-detects the WAN IP on a timer and updates DNSimple directly.
# No inbound HTTP needed. Use this when no router can/will speak HTTP to you.

# Enable by setting an interval (minimum 30s).
# POLL_INTERVAL=5m

# Required when POLL_INTERVAL is set. Comma-separated.
# POLL_HOSTNAMES=home.example.com,vpn.example.com

# IP-discovery service. Default returns the public IP as plain text.
# POLL_IP_SOURCE=https://api.ipify.org

# ---- Misc ------------------------------------------------------------------
# Point at the sandbox while testing.
# DNSIMPLE_API=https://api.sandbox.dnsimple.com

# TTL applied to newly created records (default 60s).
# Existing records keep their TTL on update.
# RECORD_TTL=60